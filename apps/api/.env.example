PORT=3001
HOST=127.0.0.1
TRANSCRIBE_TIMEOUT_MS=900000
VIDEO_COMPRESS_TIMEOUT_MS=3600000
MAX_UPLOAD_SIZE_GB=10
TRANSCRIBE_SILENCE_NOISE_DB=-35dB
TRANSCRIBE_MIN_SILENCE_SECONDS=1
TRANSCRIBE_SPEECH_PADDING_SECONDS=0.25
TRANSCRIBE_MIN_SPEECH_SECONDS=0.4

# Optional absolute paths if commands are installed but not visible in PATH:
# YTDLP_COMMAND=/opt/homebrew/bin/yt-dlp
# FFMPEG_COMMAND=/opt/homebrew/bin/ffmpeg
# FFPROBE_COMMAND=/opt/homebrew/bin/ffprobe

# Local engine priority:
# openai-whisper/local-file: ffmpeg streams to a temp WAV file, then OpenAI Whisper CLI reads that file.
# mlx-whisper: ffmpeg streams to a temp WAV file, then MLX Whisper reads that file.
# local-stdin: ffmpeg stdout is piped into the configured whisper command stdin.
# openai: sends a temp WAV file to OpenAI Audio Transcriptions API.
TRANSCRIPTION_ENGINE=openai-whisper

# Common openai-whisper CLI example:
WHISPER_COMMAND=whisper
# WHISPER_COMMAND=/Users/your-user/.local/bin/whisper
WHISPER_ARGS={input} --model base --language ru --condition_on_previous_text False --word_timestamps True --hallucination_silence_threshold 2 --clip_timestamps {clipTimestamps} --output_format txt --output_dir {outputDir}

# MLX Whisper for Apple Silicon GPU/Metal acceleration:
# MLX_WHISPER_COMMAND=/Users/your-user/.local/bin/mlx_whisper
MLX_WHISPER_ARGS={input} --model mlx-community/whisper-large-v3-turbo --language ru --condition-on-previous-text False --word-timestamps True --hallucination-silence-threshold 2 --clip-timestamps {clipTimestamps} -f txt -o {outputDir}

# Example for a stdin-capable whisper.cpp build, if yours supports "-":
# TRANSCRIPTION_ENGINE=local-stdin
# WHISPER_COMMAND=whisper-cli
# WHISPER_ARGS=-f - -otxt

# Optional OpenAI fallback:
# OPENAI_API_KEY=sk-...
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
