{
  "name": "@transcribator/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @transcribator/shared build && tsx src/index.ts",
    "build": "pnpm --filter @transcribator/shared build && tsc",
    "typecheck": "pnpm --filter @transcribator/shared build && tsc --noEmit",
    "check": "pnpm typecheck"
  },
  "dependencies": {
    "@transcribator/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "multer": "^2.1.1",
    "openai": "^4.87.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
