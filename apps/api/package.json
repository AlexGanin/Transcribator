{
  "name": "@transcribator/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @transcribator/shared build && tsx src/index.ts",
    "build": "pnpm --filter @transcribator/shared build && tsc",
    "typecheck": "pnpm --filter @transcribator/shared build && tsc --noEmit",
    "check": "pnpm typecheck"
  },
  "dependencies": {
    "@transcribator/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "openai": "^6.43.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.13.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
