{
  "name": "@transcribator/extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @transcribator/shared build && pnpm --filter @transcribator/api-client build && wxt",
    "build": "pnpm --filter @transcribator/shared build && pnpm --filter @transcribator/api-client build && wxt build",
    "typecheck": "pnpm --filter @transcribator/shared build && pnpm --filter @transcribator/api-client build && wxt prepare && tsc --noEmit",
    "check": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@transcribator/api-client": "workspace:*",
    "@transcribator/shared": "workspace:*",
    "@wxt-dev/module-react": "^1.1.3",
    "wxt": "^0.20.26",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^6.0.3"
  }
}
